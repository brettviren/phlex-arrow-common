@PACKAGE_INIT@

# phlex_arrow_common: Phlex-aware, technology-agnostic Arrow glue.
# Target: phlex_arrow_common::phlex_arrow_common
# Deps: Apache Arrow (the narrow-waist intermediate) and Phlex (+ its
# un-found-dependency deps TBB/Boost/spdlog).  NOT any technology serializer.

include(CMakeFindDependencyMacro)
find_dependency(Arrow)
find_dependency(TBB)
find_dependency(Boost)
find_dependency(spdlog)
find_dependency(phlex)

include("${CMAKE_CURRENT_LIST_DIR}/phlex_arrow_commonTargets.cmake")
